# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# SMTP (Gmail example - use app password, not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-16-chars

# Admin email (who receives booking notifications)
ADMIN_EMAIL=carolyn@example.com

# Google Calendar (optional - leave blank if not set up yet)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# Session/JWT
JWT_SECRET=your-secret-key-min-32-characters

# Site
NEXT_PUBLIC_SITE_URL=https://carolynclarkwebsite.vercel.app

# Cloudflare Turnstile (Sign up at https://dash.cloudflare.com/sign-up/turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
